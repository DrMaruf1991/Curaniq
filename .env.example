# ──────────────────────────────────────────────────────────────────────────
# CURANIQ environment template — copy to .env and fill in real values
# .env is in .gitignore and MUST NEVER be committed
# ──────────────────────────────────────────────────────────────────────────

# Runtime safety mode: demo | research | clinician_prod
# clinician_prod fails closed without governed evidence + Postgres
CURANIQ_ENV=demo

# Production API guard (replace with JWT/OIDC before hospital deployment)
CURANIQ_API_KEY=
CURANIQ_CORS_ORIGINS=https://app.curaniq.com

# ──────────────────────────────────────────────────────────────────────────
# PostgreSQL — set a strong password; never commit the real value
# ──────────────────────────────────────────────────────────────────────────
POSTGRES_USER=curaniq
POSTGRES_PASSWORD=
POSTGRES_DB=curaniq
CURANIQ_DATABASE_URL=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}
CURANIQ_DB_POOL_SIZE=5
CURANIQ_DB_POOL_OVERFLOW=10
CURANIQ_DB_POOL_RECYCLE=3600

# Audit ledger: jsonl (dev) | memory (tests) | postgresql (production)
CURANIQ_AUDIT_BACKEND=postgresql
CURANIQ_AUDIT_PATH=./curaniq_audit.jsonl

# Source registry hydration from Postgres
CURANIQ_SOURCE_REGISTRY_DB=1
CURANIQ_EVIDENCE_DB=1

# Evidence APIs (request keys from each provider)
NCBI_API_KEY=
OPENFDA_API_KEY=

# LLM providers (clinician_prod requires at least one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Cryptographic signing of clinician review records
CURANIQ_REVIEW_SECRET=