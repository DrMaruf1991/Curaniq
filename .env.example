# CURANIQ runtime safety mode
# demo: permits seed/mock paths for UI/demo testing
# research: permits labeled non-production behavior
# clinician_prod: fail-closed; no seed evidence; no mock LLM; no stale high-risk evidence;
#                 requires reachable database (FIX-31)
CURANIQ_ENV=clinician_prod

# Production API guard; replace with JWT/OIDC before hospital deployment
CURANIQ_API_KEY=change-me
CURANIQ_CORS_ORIGINS=https://app.curaniq.com

# ──────────────────────────────────────────────────────────────────────────
# Database (FIX-31 Postgres backbone)
# Set CURANIQ_DATABASE_URL to a real Postgres URL in production.
# Local dev with docker-compose: postgresql+psycopg2://curaniq:curaniq@localhost:5432/curaniq
# Local dev without Postgres: defaults to sqlite:///./curaniq_dev.db (NOT for production)
# ──────────────────────────────────────────────────────────────────────────
CURANIQ_DATABASE_URL=
CURANIQ_DB_POOL_SIZE=5
CURANIQ_DB_POOL_OVERFLOW=10
CURANIQ_DB_POOL_RECYCLE=3600

# Audit ledger backend: jsonl (default), memory (tests), postgresql (FIX-31)
CURANIQ_AUDIT_BACKEND=postgresql

# Source registry: hydrate from DB on boot (recommended for production)
CURANIQ_SOURCE_REGISTRY_DB=1

# Evidence APIs
NCBI_API_KEY=
OPENFDA_API_KEY=

# LLM providers. In clinician_prod, at least one verified provider must be configured.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Audit storage
CURANIQ_AUDIT_PATH=./curaniq_audit.jsonl
CURANIQ_REVIEW_SECRET=change-me-for-signing

# Truth Core / Postgres Enforcement Phase
CURANIQ_ENV=demo
# For clinician production, set all of these and run Alembic migrations first:
# CURANIQ_ENV=clinician_prod
# CURANIQ_DATABASE_URL=postgresql+psycopg2://curaniq:curaniq_dev_password@localhost:5432/curaniq
# CURANIQ_AUDIT_BACKEND=postgresql
# CURANIQ_SOURCE_REGISTRY_DB=1
# CURANIQ_EVIDENCE_DB=1
# CURANIQ_API_KEY=change-me
