      "cognitive_risk": true,
      "acb": 3,
      "quality": "moderate",
      "strength": "strong"
    },
    {
      "drug": "imipramine",
      "class": "tca",
      "rationale": "Anticholinergic TCA; orthostatic hypotension",
      "recommendation": "Avoid.",
      "falls_risk": true,
      "cognitive_risk": true,
      "acb": 3,
      "quality": "high",
      "strength": "strong"
    },
    {
      "drug": "nortriptyline",
      "class": "tca",
      "rationale": "Less anticholinergic TCA but still risky in elderly",
      "recommendation": "Avoid.",
      "falls_risk": true,
      "cognitive_risk": true,
      "acb": 1,
      "quality": "moderate",
      "strength": "strong"
    },
