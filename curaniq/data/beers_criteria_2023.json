  "avoid_in_older_adults": [
    {
      "drug": "alprazolam",
      "class": "benzodiazepine",
      "rationale": "Increased sensitivity, prolonged sedation, falls, fractures, cognitive impairment, delirium",
      "recommendation": "Avoid. Non-pharmacological approaches preferred.",
      "falls_risk": true,
      "cognitive_risk": true,
      "acb": 1,
      "quality": "moderate",
      "strength": "strong"
    },
    {
      "drug": "chlordiazepoxide",
      "class": "benzodiazepine",
      "rationale": "Long-acting BZD; prolonged half-life up to 200h with metabolites",
      "recommendation": "Avoid. If BZD required: lorazepam or oxazepam.",
      "falls_risk": true,
      "cognitive_risk": true,
      "acb": 0,
      "quality": "moderate",
      "strength": "strong"
    },
    {
      "drug": "clonazepam",
      "class": "benzodiazepine",
      "rationale": "Long-acting BZD; CNS depression, falls",
      "recommendation": "Avoid for insomnia, agitation, delirium.",
      "falls_risk": true,
      "cognitive_risk": true,
      "acb": 0,
      "quality": "moderate",
      "strength": "strong"
    },
    {
      "drug": "diazepam",
      "class": "benzodiazepine",
      "rationale": "Very long-acting BZD; active metabolite desmethyldiazepam t1/2 >100h",
      "recommendation": "Avoid. Use short-acting BZD if absolutely necessary.",
      "falls_risk": true,
      "cognitive_risk": true,
      "acb": 1,
      "quality": "moderate",
      "strength": "strong"
    },
    {
      "drug": "flurazepam",
      "class": "benzodiazepine",
      "rationale": "Long-acting BZD hypnotic; next-day sedation",
      "recommendation": "Avoid.",
      "falls_risk": true,
      "cognitive_risk": true,
      "acb": 0,
      "quality": "moderate",
      "strength": "strong"
    },
    {
      "drug": "lorazepam",
      "class": "benzodiazepine",
      "rationale": "Short-acting but still carries BZD class risks in elderly",
      "recommendation": "Avoid for insomnia. If used for anxiety: lowest dose, shortest duration.",
      "falls_risk": true,
      "cognitive_risk": true,
      "acb": 0,
      "quality": "moderate",
      "strength": "strong"
    },
    {
      "drug": "temazepam",
      "class": "benzodiazepine",
      "rationale": "BZD hypnotic; falls and fracture risk",
      "recommendation": "Avoid.",
      "falls_risk": true,
      "cognitive_risk": true,
      "acb": 0,
      "quality": "moderate",
      "strength": "strong"
    },
    {
      "drug": "triazolam",
      "class": "benzodiazepine",
      "rationale": "Ultra-short BZD but rebound insomnia, amnesia",
      "recommendation": "Avoid.",
      "falls_risk": true,
      "cognitive_risk": true,
      "acb": 0,
      "quality": "moderate",
      "strength": "strong"
    },
    {
      "drug": "zolpidem",
      "class": "z_drug",
      "rationale": "Z-drug with BZD-like risks. ER visits 8x higher in >65",
      "recommendation": "Avoid. Melatonin 0.5-2mg or trazodone low-dose if needed.",
      "falls_risk": true,
      "cognitive_risk": true,
      "acb": 0,
      "quality": "moderate",
      "strength": "strong"
    },
    {
      "drug": "zaleplon",
      "class": "z_drug",
      "rationale": "Z-drug; similar risks to zolpidem",
      "recommendation": "Avoid.",
      "falls_risk": true,
      "cognitive_risk": true,
      "acb": 0,
      "quality": "moderate",
      "strength": "strong"
    },
    {
      "drug": "eszopiclone",
      "class": "z_drug",
      "rationale": "Z-drug; prolonged sedation in elderly",
      "recommendation": "Avoid.",
      "falls_risk": true,
      "cognitive_risk": true,
      "acb": 0,
      "quality": "moderate",
      "strength": "strong"
    },
    {
      "drug": "amitriptyline",
