  "multimorbidity_conflicts": [
    {
      "cond_a": "heart_failure",
      "drug": "nsaid",
      "cond_b": "pain",
      "conflict": "NSAIDs cause fluid retention, worsen HF",
      "recommendation": "Use paracetamol. If NSAID essential: lowest dose, shortest duration.",
      "source": "NICE NG106"
    },
    {
      "cond_a": "asthma",
      "drug": "beta_blocker_nonselective",
      "cond_b": "hypertension",
      "conflict": "Non-selective BB can trigger bronchospasm",
      "recommendation": "Use cardioselective (bisoprolol). Avoid propranolol/carvedilol.",
      "source": "BTS/SIGN 2019"
    },
    {
      "cond_a": "ckd",
      "drug": "nsaid",
      "cond_b": "pain",
      "conflict": "NSAIDs reduce renal blood flow, accelerate CKD",
      "recommendation": "AVOID if eGFR <30. Max 5 days if 30-60.",
      "source": "KDIGO 2024"
    },
    {
      "cond_a": "diabetes",
      "drug": "thiazide_high_dose",
      "cond_b": "hypertension",
      "conflict": "High-dose thiazides worsen glycemic control",
      "recommendation": "Low-dose (HCTZ 12.5-25mg). Monitor HbA1c.",
      "source": "ADA 2024"
    },
    {
      "cond_a": "gout",
      "drug": "thiazide",
      "cond_b": "hypertension",
      "conflict": "Thiazides increase uric acid",
      "recommendation": "Add allopurinol. Consider losartan (uricosuric).",
      "source": "ACR 2020"
    },
    {
      "cond_a": "depression",
      "drug": "beta_blocker_lipophilic",
      "cond_b": "hypertension",
      "conflict": "Lipophilic BB may worsen depression",
      "recommendation": "Use hydrophilic (atenolol) or alternative class.",
      "source": "NICE CG90"
    },
    {
      "cond_a": "peptic_ulcer",
      "drug": "anticoagulant",
      "cond_b": "atrial_fibrillation",
      "conflict": "Anticoagulation increases GI bleeding risk",
      "recommendation": "PPI mandatory. H.pylori eradication. Prefer apixaban.",
      "source": "ESC 2024"
    },
    {
      "cond_a": "osteoporosis",
      "drug": "corticosteroid",
      "cond_b": "inflammation",
      "conflict": "Corticosteroids accelerate bone loss",
      "recommendation": "Calcium + VitD + bisphosphonate if >3 months.",
      "source": "ACR 2022 GIOP"
    },
    {
      "cond_a": "diabetes",
      "drug": "corticosteroid",
      "cond_b": "inflammation",
      "conflict": "Corticosteroids cause hyperglycemia",
      "recommendation": "Monitor glucose QID. May need insulin adjustment.",
      "source": "JBDS-IP Steroid Diabetes 2021"
    }
