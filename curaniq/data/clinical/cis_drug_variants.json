    "source_url": "https://rxnav.nlm.nih.gov + https://uzpharm.uz",
    "license_status": "open",
    "extraction_method": "manual_curation",
    "is_authoritative": false,
    "refresh_command": "python -m curaniq.knowledge.refresh drug_localizations --source rxnorm,uz_moh",
