        "intermediate_metabolizer",
        "normal_metabolizer"
      ],
      "drugs": {
        "fluorouracil": {
          "action_pm": "CONTRAINDICATED. Fatal toxicity risk.",
          "action_im": "Reduce dose 50%. Monitor closely.",
          "action_normal": "Standard dosing.",
          "cpic_level": "A",
          "source": "CPIC Fluoropyrimidines 2023; EMA mandatory testing 2020"
        },
        "capecitabine": {
          "action_pm": "CONTRAINDICATED. Fatal toxicity.",
          "action_im": "Reduce dose 50%.",
          "action_normal": "Standard dosing.",
          "cpic_level": "A",
          "source": "CPIC Fluoropyrimidines 2023"
        }
      }
    },
    "TPMT_NUDT15": {
      "description": "Thiopurine methyltransferase / NUDT15 — thiopurine toxicity",
      "phenotypes": [
        "poor_metabolizer",
        "intermediate_metabolizer",
        "normal_metabolizer"
      ],
      "drugs": {
        "azathioprine": {
          "action_pm": "Reduce dose 90% or AVOID.",
          "action_im": "Reduce dose 30-80%.",
          "action_normal": "Standard dosing.",
          "cpic_level": "A",
          "source": "CPIC Thiopurines 2018"
        },
        "mercaptopurine": {
          "action_pm": "Reduce dose 90% or AVOID.",
          "action_im": "Reduce dose 30-80%.",
          "action_normal": "Standard dosing.",
          "cpic_level": "A",
          "source": "CPIC Thiopurines 2018"
        }
      }
    }
  }
